MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/noir_ash
JWT_SECRET=replace-with-a-long-random-string
QR_SIGNING_SECRET=replace-with-a-different-long-random-string
CORS_ORIGIN=http://localhost:5173
PORT=4000

# Online payments (reservation deposit)
# Leave RAZORPAY_KEY_ID / RAZORPAY_KEY_SECRET blank to run in mock payment mode
# (no real gateway, useful for local dev). Get real test/live keys from
# https://dashboard.razorpay.com/app/keys and run `npm install razorpay` to go live.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
DEPOSIT_PER_GUEST_INR=200
